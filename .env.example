# SRCA AI Workspace environment

# Where to proxy AICP API calls (server-side rewrite target). In dev this is the
# AICP backend; in prod point it at the AICP API gateway.
API_INTERNAL_URL=http://localhost:8000

# Public URL of the AICP console, used for cross-app links (e.g. opening an AICP
# admin surface from a SRCA AI Workspace Center). Defaults to the dev AICP web app.
NEXT_PUBLIC_AICP_URL=http://localhost:3000

# AICP connector id for the SRCA 997 data lake. When set, the command center loads
# every surface live via POST /api/v1/connectors/<id>/query { statement_key } (see
# lib/command-center-source.ts). When unset, all surfaces fall back to local mock
# data. The workspace never connects to the database directly — AICP mediates reads.
# SRCA_DATALAKE_CONNECTOR_ID=

# Command-center AI surfaces (also editable at /settings/aicp). Every AI surface calls an AICP
# AI Capability by id — the capability owns the prompt, model and grounding; the workspace only
# invokes /ai-capabilities/{id}/run and renders the result. Blank = that surface shows empty.
# SRCA_BRIEFING_CAPABILITY_ID=          # returns JSON {headline, bullets}
# SRCA_FORECAST_CAPABILITY_ID=          # returns JSON {forecast:[{label,value,confidence}]}
# SRCA_RECOMMENDATIONS_CAPABILITY_ID=   # returns JSON {recommendations:[...]}
# SRCA_COPILOT_CAPABILITY_ID=           # conversational; text output
# SRCA_KNOWLEDGE_CAPABILITY_ID=         # knowledge/RAG; text output (+ citations in meta)
